	#G_WLAN0_MAC6_LAST4_INT=`printf "%d\n" $(($WLAN0_MAC6_LAST4))`
	G_WLAN0_MAC6_LAST4_INT=`expr $G_WLAN0_MAC4_LAST4_INT + $G_ETH0_MAC4_LAST4_INT`
