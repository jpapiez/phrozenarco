	G_WLAN0_MAC6_LAST4_INT=$(expr $G_WLAN0_MAC6_LAST4_INT / 2)
	echo "G_WLAN0_MAC6_LAST4_INT=$G_WLAN0_MAC6_LAST4_INT"
}

